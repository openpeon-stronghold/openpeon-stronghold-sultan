{
  "cesp_version": "1.0",
  "name": "stronghold-sultan",
  "display_name": "The Sultan (Stronghold Crusader)",
  "version": "1.0.0",
  "author": { "name": "Marko Jevic", "github": "koyev" },
  "license": "fair-use",
  "language": "en",
  "categories": {
    "session.start": {
      "sounds": [
        { "file": "sounds/su_add_player_01.wav", "label": "Oh!" }
      ]
    },
    "task.acknowledge": {
      "sounds": [
        { "file": "sounds/su_willattack_01.wav", "label": "If you will it" },
        { "file": "sounds/su_sent_01.wav", "label": "Yes! I have what you need" },
        { "file": "sounds/su_siege_01.wav", "label": "Tigers ready to pounce" }
      ]
    },
    "task.complete": {
      "sounds": [
        { "file": "sounds/su_vict_01.wav", "label": "The lion has roared" },
        { "file": "sounds/su_boast_01.wav", "label": "Lamb fallen to the Sultan's beak" },
        { "file": "sounds/su_vict_03.wav", "label": "Swift passage to heaven" }
      ]
    },
    "task.error": {
      "sounds": [
        { "file": "sounds/su_anger_01.wav", "label": "Sky not bright today" },
        { "file": "sounds/su_anger_02.wav", "label": "Olive branches weep" }
      ]
    },
    "input.required": {
      "sounds": [
        { "file": "sounds/su_help_01.wav", "label": "Vultures fly high" },
        { "file": "sounds/su_nervous_01.wav", "label": "Red sky approaches" },
        { "file": "sounds/su_req_01.wav", "label": "We are in need" }
      ]
    },
    "resource.limit": {
      "sounds": [
        { "file": "sounds/su_notsent_01.wav", "label": "Camels will stay tethered" },
        { "file": "sounds/su_nohelp_02.wav", "label": "Sultan weeps for you" }
      ]
    },
    "user.spam": {
      "sounds": [
        { "file": "sounds/su_noattack_02.wav", "label": "Maybe tomorrow but not now" },
        { "file": "sounds/su_kick_player_01.wav", "label": "Oh dear!" }
      ]
    }
  }
}
